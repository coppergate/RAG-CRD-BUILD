{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryWriteRequest",
  "type": "object",
  "required": ["request_id", "scope", "writes"],
  "properties": {
    "request_id": {"type": "string"},
    "correlation_id": {"type": "string"},
    "scope": {
      "type": "object",
      "properties": {
        "session_id": {"type": "integer"},
        "user_id": {"type": "string"},
        "project_id": {"type": "integer"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "writes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["memory_type", "summary"],
        "properties": {
          "memory_id": {"type": "integer"},
          "memory_type": {
            "type": "string",
            "enum": ["short_term_memory", "long_term_memory", "persistent_memory"]
          },
          "summary": {"type": "string"},
          "content": {"type": "string"},
          "salience_hint": {"type": "number", "minimum": 0, "maximum": 1},
          "retention_hint": {"type": "number", "minimum": 0, "maximum": 1},
          "pinned": {"type": "boolean"},
          "expires_at": {"type": "string", "format": "date-time"},
          "metadata": {"type": "object"},
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_kind", "source_id", "relation_type"],
              "properties": {
                "source_kind": {
                  "type": "string",
                  "enum": ["prompt", "response", "ingestion", "manual", "system"]
                },
                "source_id": {"type": "string"},
                "relation_type": {
                  "type": "string",
                  "enum": ["derived_from", "supports", "contradicts", "corrects"]
                },
                "weight": {"type": "number"},
                "metadata": {"type": "object"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
