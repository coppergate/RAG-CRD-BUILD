{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryPack",
  "type": "object",
  "required": ["request_id", "generated_at", "items", "token_budget"],
  "properties": {
    "request_id": {"type": "string"},
    "correlation_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "mode": {"type": "string", "enum": ["off", "session", "full"]},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["memory_id", "memory_type", "summary", "rank_score"],
        "properties": {
          "memory_id": {"type": "integer"},
          "memory_type": {
            "type": "string",
            "enum": ["short_term_memory", "long_term_memory", "persistent_memory"]
          },
          "summary": {"type": "string"},
          "content": {"type": "string"},
          "salience": {"type": "number"},
          "retention_score": {"type": "number"},
          "rank_score": {"type": "number"},
          "token_estimate": {"type": "integer", "minimum": 0},
          "why_selected": {"type": "string"},
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_kind": {"type": "string"},
                "source_id": {"type": "string"},
                "relation_type": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "metadata": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "token_budget": {
      "type": "object",
      "required": ["max_tokens", "used_tokens"],
      "properties": {
        "max_tokens": {"type": "integer", "minimum": 0},
        "used_tokens": {"type": "integer", "minimum": 0},
        "short_term_used": {"type": "integer", "minimum": 0},
        "long_term_used": {"type": "integer", "minimum": 0},
        "persistent_used": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "dropped": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "memory_id": {"type": "integer"},
          "reason": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "winner_memory_id": {"type": "integer"},
          "loser_memory_id": {"type": "integer"},
          "resolution": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
