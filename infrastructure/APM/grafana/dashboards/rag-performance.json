  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rates (Gateway & UI)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(gateway_requests_total[5m])) by (service_name)", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_ms_bucket[5m])) by (le, service_name))", "legendFormat": "Gateway P95 {{service_name}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(worker_task_duration_ms_bucket[5m])) by (le, stage))", "legendFormat": "Worker P95 {{stage}}" }
      ]
    },
    {
      "title": "Error Counts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(gateway_errors_total[5m])) by (service_name, type)", "legendFormat": "Error {{service_name}} {{type}}" },
        { "expr": "sum(rate(db_errors_total[5m])) by (operation)", "legendFormat": "DB Error {{operation}}" },
        { "expr": "sum(rate(qdrant_errors_total[5m])) by (action)", "legendFormat": "Qdrant Error {{action}}" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["rag-stack", "metrics"],
