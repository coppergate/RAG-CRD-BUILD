    {
      "title": "Error Logs by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (app) (count_over_time({namespace=\"rag-system\"} |= \"error\" [5m]))",
          "legendFormat": "{{app}}"
        },
        {
            "expr": "sum by (app) (count_over_time({namespace=\"rag-system\"} |= \"fail\" [5m]))",
            "legendFormat": "{{app}} (fail)"
        }
      ]
    },
    {
      "title": "Recent Error Log Lines",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{namespace=\"rag-system\"} |= \"error\" or |= \"fail\" or |= \"Warning\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogLines": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
